{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block content %}
<div
    data-controller="admin-dashboard"
    data-admin-dashboard-mercure-url-value="{{ mercurePublicUrl }}"
>

    {# Row 1 — KPI Cards #}
    <div class="row g-3 mb-4">
        {% set kpi_cards = [
            { key: 'schools',      label: 'Schools',       icon: 'fa-school',         color: 'primary' },
            { key: 'users',        label: 'Users',         icon: 'fa-users',          color: 'secondary' },
            { key: 'students',     label: 'Students',      icon: 'fa-user-graduate',  color: 'info' },
            { key: 'drivers',      label: 'Drivers',       icon: 'fa-bus',            color: 'warning' },
            { key: 'activeRoutes', label: 'Active Routes', icon: 'fa-route',          color: 'success' },
            { key: 'openAlerts',   label: 'Open Alerts',   icon: 'fa-triangle-exclamation', color: 'danger' },
        ] %}

        {% for card in kpi_cards %}
        <div class="col-12 col-sm-6 col-xl-2">
            <div class="card text-bg-{{ card.color }} h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <i class="fas {{ card.icon }} fa-2x opacity-75"></i>
                    <div>
                        <div
                            class="fs-2 fw-bold"
                            data-admin-dashboard-target="kpiCard"
                            data-stat="{{ card.key }}"
                        >{{ kpis[card.key] }}</div>
                        <div class="small">{{ card.label }}</div>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    {# Row 2 — Charts #}
    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-8">
            <div class="card h-100">
                <div class="card-header fw-semibold">Routes — last 7 days</div>
                <div class="card-body">
                    {{ render_chart(weeklyChart, { 'style': 'height: 260px' }) }}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">Alert distribution</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    {{ render_chart(alertChart, { 'style': 'height: 260px' }) }}
                </div>
            </div>
        </div>
    </div>

    {# Row 3 — Live Tables #}
    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header fw-semibold">
                    <i class="fas fa-route me-1"></i> Active Routes Now
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0" id="active-routes-table">
                        <thead>
                            <tr>
                                <th>Driver</th>
                                <th>Started</th>
                                <th>Progress</th>
                            </tr>
                        </thead>
                        <tbody data-dashboard-target="routesTbody">
                        {% if activeRoutes is empty %}
                            <tr><td colspan="3" class="text-center text-muted py-3">No active routes</td></tr>
                        {% else %}
                            {% for route in activeRoutes %}
                            <tr data-route-id="{{ route.id }}">
                                <td>{{ route.driverName }}</td>
                                <td>{{ route.startedAt ?? '—' }}</td>
                                <td>
                                    <div class="progress" style="height: 6px;" title="{{ route.progressPct }}%">
                                        <div class="progress-bar bg-success" style="width: {{ route.progressPct }}%"></div>
                                    </div>
                                    <small class="text-muted">{{ route.completedStops }}/{{ route.totalStops }}</small>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header fw-semibold">
                    <i class="fas fa-triangle-exclamation me-1 text-danger"></i> Open SOS Alerts
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0" id="alerts-table">
                        <thead>
                            <tr>
                                <th>Driver</th>
                                <th>Status</th>
                                <th>Triggered</th>
                            </tr>
                        </thead>
                        <tbody data-dashboard-target="alertsTbody">
                        {% if openAlerts is empty %}
                            <tr><td colspan="3" class="text-center text-muted py-3">No open alerts</td></tr>
                        {% else %}
                            {% for alert in openAlerts %}
                            <tr data-alert-id="{{ alert.alertId }}">
                                <td>{{ alert.driverName }}</td>
                                <td>
                                    <span class="badge bg-{{ alert.status == 'PENDING' ? 'danger' : 'warning' }}">
                                        {{ alert.status }}
                                    </span>
                                </td>
                                <td><small>{{ alert.triggeredAt }}</small></td>
                            </tr>
                            {% endfor %}
                        {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
